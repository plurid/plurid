{
    "compilerOptions": {
        "module": "ES2022",
        "moduleResolution": "node",
        "target": "ES2022",
        "lib": ["DOM", "ES2022"],
        "jsx": "react",

        "baseUrl": ".",
        "paths": {
            "~constants/*": [
                "./source/constants/*"
            ],
            "~enumerations/*": [
                "./source/enumerations/*"
            ],
            "~icons/*": [
                "./source/icons/*"
            ],
            "~interfaces/*": [
                "./source/interfaces/*"
            ],
        },

        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types",
        ],

        "declaration": true,
        "declarationDir": "distribution",
        "sourceMap": true,
        "allowJs": false,
        "esModuleInterop": true,
        "downlevelIteration": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,

        "strict": true,
        "strictNullChecks": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noImplicitAny": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,

        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

    },
    "include": [
        "source/**/*"
    ],
    "exclude": [
        "node_modules",
        "build",
        "distribution",
        "scripts"
    ]
}
