{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~constants/*": [
                "./source/constants/*"
            ],
            "~enumerations/*": [
                "./source/enumerations/*"
            ],
            "~icons/*": [
                "./source/icons/*"
            ],
            "~interfaces/*": [
                "./source/interfaces/*"
            ]
        },
        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source/**/*"
    ],
    "exclude": [
        "node_modules",
        "build",
        "distribution",
        "scripts"
    ]
}
