{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~data/*": [
                "./source/data/*"
            ],
            "~components/*": [
                "./source/components/*"
            ],
            "~utilities/*": [
                "./source/utilities/*"
            ]
        },
        "outDir": "build",
        "typeRoots": [
            "node_modules/@types"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source/**/*"
    ],
    "exclude": [
        "unsource",
        "node_modules",
        "build",
        "distribution",
        "scripts"
    ]
}
