        "@plurid/plurid-ui-state-react": "*",
        "@reduxjs/toolkit": ">=2",
        "react": ">=18",
        "react-dom": ">=18",
        "react-redux": ">=9",
        "styled-components": ">=5"
    },
    "devDependencies": {
        "@babel/core": "^7.22.5",
        "@plurid/plurid-functions": "workspace:*",
        "@plurid/plurid-functions-react": "workspace:*",
        "@plurid/plurid-icons-react": "workspace:*",
        "@plurid/plurid-themes": "workspace:*",
        "@plurid/plurid-ui-state-react": "workspace:*",
        "@reduxjs/toolkit": "^2.12.0",
        "@rollup/plugin-terser": "^0.4.3",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.3",
        "@types/react": "^18.2.14",
        "@types/react-dom": "^18.2.6",
        "@types/react-redux": "^7.1.25",
        "@types/styled-components": "^5.1.26",
        "@typescript-eslint/eslint-plugin": "^5.60.1",
        "@typescript-eslint/parser": "^5.60.1",
        "eslint": "^8.44.0",
        "immer": "^10.0.2",
        "jest": "^29.5.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-redux": "^9.3.0",
        "redux": "^5.0.1",
        "redux-thunk": "^3.1.0",
        "styled-components": "==5.3.10",
        "ts-jest": "^29.1.1",
        "ts-patch": "^3.0.1",
        "typescript": "^5.9.3",
        "typescript-transform-paths": "^3.4.6",
        "tsup": "^8.5.1"
    },
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.mjs",
            "require": "./distribution/index.js"
        }
    }
}
