{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~data/*": [
                "./source/data/*"
            ],
            "~inquire/*": [
                "./source/inquire/*"
            ],
            "~process/*": [
                "./source/process/*"
            ],
            "~utilities/*": [
                "./source/utilities/*"
            ]
        },
        "outDir": "distribution",
        "declarationDir": "distribution"
    },
    "include": [
        "source"
    ],
    "exclude": [
        "node_modules",
        "distribution",
        "source/files",
        "unsource"
    ]
}
