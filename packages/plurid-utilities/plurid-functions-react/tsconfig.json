{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "#hooks/*": [
                "./source/hooks/*"
            ],
            "#utilities/*": [
                "./source/utilities/*"
            ]
        },
        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source/**/*"
    ],
    "exclude": [
        "node_modules",
        "build",
        "distribution",
        "scripts"
    ]
}
