{
    "name": "@plurid/plurid-routes-server",
    "version": "0.0.0-0",
    "sideEffects": false,
    "description": "Plurid Routes Retrieval and Registration",
    "keywords": [
        "plurid",
        "routes",
        "server"
    ],
    "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/plurid/plurid"
    },
    "bugs": {
        "email": "source@plurid.com",
        "url": "https://github.com/plurid/plurid/issues"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "homepage": "https://github.com/plurid/plurid/tree/master/packages/plurid-utilities/plurid-routes-server",
    "files": [
        "distribution/"
    ],
    "main": "distribution/index.js",
    "module": "distribution/index.mjs",
    "types": "distribution/index.d.ts",
    "engines": {
        "node": ">=12",
        "npm": ">=6"
    },
    "scripts": {
        "clean": "rm -rf ./distribution",
        "clean.tests": "find ./distribution -type d -name \"__tests__\" -prune -exec rm -rf {} +",
        "test": "jest ./source --config ./configurations/jest.config.js --rootDir ./",
        "lint": "eslint -c ./configurations/.eslintrc.js ./source --ext .ts,.tsx",
        "build.development": "tsup --watch",
        "build.production": "tsup",
        "build": "tsup",
        "prepublishOnly": "pnpm build"
    },
    "peerDependencies": {
        "@plurid/deon": "*",
        "@plurid/plurid-functions": "*",
        "body-parser": ">=1.19",
        "express": ">=4.17"
    },
    "devDependencies": {
        "@plurid/deon": "^0.0.0-10",
        "@plurid/plurid-functions": "workspace:*",
        "@types/express": "^4.17.14",
        "@types/jest": "^29.0.3",
        "@typescript-eslint/eslint-plugin": "^5.38.1",
        "@typescript-eslint/parser": "^5.38.1",
        "body-parser": "^1.20.0",
        "eslint": "^8.24.0",
        "express": "^4.18.1",
        "jest": "^29.1.1",
        "jest-config": "^29.1.1",
        "ts-jest": "^29.0.2",
        "ts-node": "^10.9.1",
        "typescript": "^5.9.3",
        "tsup": "^8.5.1",
        "@types/body-parser": "^1.19.5"
    },
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.mjs",
            "require": "./distribution/index.js"
        }
    }
}
