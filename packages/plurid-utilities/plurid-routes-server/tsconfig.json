{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~data/*": [
                "./source/data/*"
            ],
            "~objects/*": [
                "./source/objects/*"
            ]
        },
        "rootDir": "./source",
        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types",
            "source/types/typings.d.ts"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source"
    ],
    "exclude": [
        "node_modules",
        "distribution",
        "unsource"
    ]
}
