{
  "name": "@plurid/plurid-themes",
  "version": "0.0.0-2",
  "sideEffects": false,
  "description": "Themes for Plurid Applications",
  "keywords": [
    "plurid",
    "applications",
    "themes"
  ],
  "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/plurid/plurid-themes"
  },
  "bugs": {
    "email": "source@plurid.com",
    "url": "https://github.com/plurid/plurid-themes/issues"
  },
  "homepage": "https://github.com/plurid/plurid-themes",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "distribution/"
  ],
  "main": "distribution/index.js",
  "module": "distribution/index.mjs",
  "types": "distribution/index.d.ts",
  "exports": {
    ".": {
      "types": "./distribution/index.d.ts",
      "import": "./distribution/index.mjs",
      "require": "./distribution/index.js"
    }
  },
  "engines": {
    "node": ">=18",
    "npm": ">=6"
  },
  "scripts": {
    "test": "jest -c ./configurations/jest.config.js source",
    "clean": "rm -rf ./distribution",
    "build.development": "tsup --watch",
    "build.production": "tsup",
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
