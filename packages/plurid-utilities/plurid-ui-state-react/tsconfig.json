{
    "extends": "../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~data/*": [
                "./source/data/*"
            ],
            "~modules/*": [
                "./source/modules/*"
            ]
        },
        "strictFunctionTypes": true,
        "alwaysStrict": true,
        "declarationDir": "distribution",
        "preserveSymlinks": true,
        "rootDir": "source",
        "outDir": "distribution"
    },
    "exclude": [
        "node_modules",
        "distribution",
        "test"
    ]
}
