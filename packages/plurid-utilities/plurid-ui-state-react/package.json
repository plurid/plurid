{
    "name": "@plurid/plurid-ui-state-react",
    "version": "0.0.0-11",
    "sideEffects": false,
    "description": "Plurid User Interface State for React",
    "keywords": [
        "plurid",
        "ui",
        "state",
        "react"
    ],
    "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/plurid/plurid-ui"
    },
    "bugs": {
        "email": "source@plurid.com",
        "url": "https://github.com/plurid/plurid-ui/issues"
    },
    "homepage": "https://github.com/plurid/plurid-ui",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "files": [
        "distribution/"
    ],
    "main": "distribution/index.js",
    "module": "distribution/index.mjs",
    "types": "distribution/index.d.ts",
    "engines": {
        "node": ">=18",
        "npm": ">=8"
    },
    "scripts": {
        "test": "jest -c ./configurations/jest.config.js",
        "lint": "eslint -c ./configurations/.eslintrc.js ./source/index.ts",
        "clean": "rm -rf ./distribution",
        "build.production": "tsup",
        "build": "tsup",
        "prepublishOnly": "pnpm build",
        "build.development": "tsup --watch"
    },
    "peerDependencies": {
        "@plurid/plurid-themes": "*",
        "@reduxjs/toolkit": ">=2"
    },
    "devDependencies": {
        "@plurid/plurid-themes": "workspace:*",
        "@reduxjs/toolkit": "^2.12.0",
        "@rollup/plugin-terser": "^0.4.3",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.3",
        "@typescript-eslint/eslint-plugin": "^5.60.1",
        "@typescript-eslint/parser": "^5.60.1",
        "@zerollup/ts-transform-paths": "^1.7.18",
        "eslint": "^8.44.0",
        "immer": "^10.0.2",
        "jest": "^29.5.0",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.1",
        "ttypescript": "^1.5.15",
        "typescript": "^5.9.3",
        "tsup": "^8.5.1"
    },
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.mjs",
            "require": "./distribution/index.js"
        }
    }
}
