{
  "name": "@plurid/plurid-react",
  "version": "0.0.0-34",
  "description": "React implementation of Plurid to explore the web in three dimensions",
  "keywords": [
    "plurid",
    "react",
    "web",
    "3D",
    "html"
  ],
  "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/plurid/plurid"
  },
  "bugs": {
    "email": "source@plurid.com",
    "url": "https://github.com/plurid/plurid/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/plurid/plurid/blob/master/packages/plurid-web/plurid-react",
  "files": [
    "distribution/"
  ],
  "main": "distribution/index.js",
  "module": "distribution/index.mjs",
  "types": "distribution/index.d.ts",
  "engines": {
    "node": ">=18",
    "npm": ">=6"
  },
  "scripts": {
    "clean": "rm -rf ./distribution",
    "test": "jest ./source --config ./configurations/jest.config.js --rootDir ./",
    "check": "tsc --project ./configurations/tsconfig.check.json",
    "types": "tsc --project ./configurations/tsconfig.types.json && rm -rf ./temporary-ts-emit",
    "build.development.only": "pnpm clean && node scripts/development.js",
    "build.development": "tsup --watch",
    "build.production": "tsup",
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@plurid/elementql": "*",
    "@plurid/elementql-client-react": "*",
    "@plurid/plurid-data": "*",
    "@plurid/plurid-engine": "*",
    "@plurid/plurid-functions": "*",
    "@plurid/plurid-functions-react": "*",
    "@plurid/plurid-icons-react": "*",
    "@plurid/plurid-pubsub": "*",
    "@plurid/plurid-themes": "*",
    "@plurid/plurid-ui-components-react": "*",
    "@plurid/plurid-ui-state-react": "*",
    "@reduxjs/toolkit": ">=2",
    "cross-fetch": ">=3",
    "react": ">=19",
    "react-dom": ">=19",
    "react-redux": ">=9",
    "styled-components": ">=6"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@plurid/elementql": "^0.0.0-1",
    "@plurid/elementql-client-react": "^0.0.0-1",
    "@plurid/plurid-data": "workspace:*",
    "@plurid/plurid-engine": "workspace:*",
    "@plurid/plurid-functions": "workspace:*",
    "@plurid/plurid-functions-react": "workspace:*",
    "@plurid/plurid-icons-react": "workspace:*",
    "@plurid/plurid-pubsub": "workspace:*",
    "@plurid/plurid-themes": "workspace:*",
    "@plurid/plurid-ui-components-react": "workspace:*",
    "@plurid/plurid-ui-state-react": "workspace:*",
    "@reduxjs/toolkit": "^2.12.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-redux": "^7.1.33",
    "@types/styled-components": "^5.1.34",
    "babel-plugin-styled-components": "^2.1.4",
    "cross-fetch": "^4.0.0",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "jest-config": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.4.33",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.3.0",
    "styled-components": "^6.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.3.1"
