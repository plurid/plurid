{
    "name": "@plurid/plurid-kit",
    "version": "0.0.0-3",
    "description": "Batteries-included framework for building and serving plurid apps - the `plurid` CLI + plurid.config.ts + conventions on top of @plurid/plurid-react-server.",
    "keywords": [
        "plurid",
        "framework",
        "react",
        "server-side rendering",
        "cli"
    ],
    "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/plurid/plurid"
    },
    "bugs": {
        "email": "source@plurid.com",
        "url": "https://github.com/plurid/plurid/issues"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "homepage": "https://github.com/plurid/plurid/blob/master/packages/plurid-web/plurid-works/plurid-kit",
    "files": [
        "distribution/",
        "templates/"
    ],
    "main": "distribution/index.js",
    "module": "distribution/index.mjs",
    "types": "distribution/index.d.ts",
    "bin": {
        "plurid": "./distribution/cli/index.js"
    },
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.mjs",
            "require": "./distribution/index.js"
        },
        "./server": {
            "types": "./distribution/server.d.ts",
            "import": "./distribution/server.mjs",
            "require": "./distribution/server.js"
        },
        "./client": {
            "types": "./distribution/client.d.ts",
            "import": "./distribution/client.mjs",
            "require": "./distribution/client.js"
        }
    },
    "engines": {
        "node": ">=18",
        "npm": ">=6"
    },
    "scripts": {
        "clean": "rm -rf ./distribution",
        "build": "tsup",
        "build.development": "tsup --watch",
        "build.production": "tsup",
        "prepublishOnly": "pnpm build",
        "test": "jest -c ./configurations/jest.config.js"
    },
    "dependencies": {
        "dotenv": "^16.4.7",
        "esbuild": "^0.25.0"
    },
    "peerDependencies": {
        "@plurid/plurid-react": "*",
        "@plurid/plurid-react-server": "*",
        "react": ">=19",
        "react-dom": ">=19",
        "react-helmet-async": ">=1",
        "react-redux": ">=9",
        "redux": ">=4",
        "styled-components": ">=6"
    },
    "devDependencies": {
        "@plurid/plurid-data": "workspace:*",
        "@plurid/plurid-engine": "workspace:*",
        "@plurid/plurid-react": "workspace:*",
        "@plurid/plurid-react-server": "workspace:*",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.10.6",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "jest": "^30.4.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-helmet-async": "^2.0.4",
        "react-redux": "^9.3.0",
        "redux": "^5.0.1",
        "styled-components": "^6.4.2",
        "ts-jest": "^29.4.11",
        "tslib": "^2.6.2",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3"
    }
}
