{
    "extends": "../../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~constants/*": [
                "./source/constants/*"
            ],
            "~enumerations/*": [
                "./source/enumerations/*"
            ],
            "~interfaces/*": [
                "./source/interfaces/*"
            ]
        },
        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types",
            "source/types/typings.d.ts"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source"
    ],
    "exclude": [
        "node_modules",
        "distribution",
        "unsource"
    ]
}
