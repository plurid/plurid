{
    "extends": "../../../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "~modules/*": [
                "./source/modules/*"
            ],
            "~interaction/*": [
                "./source/modules/interaction/*"
            ],
            "~setup/*": [
                "./source/modules/setup/*"
            ],
            "~utilities/*": [
                "./source/modules/utilities/*"
            ]
        },
        "outDir": "distribution",
        "typeRoots": [
            "node_modules/@types",
            "source/types/typings.d.ts"
        ],
        "declarationDir": "distribution"
    },
    "include": [
        "source"
    ],
    "exclude": [
        "node_modules",
        "distribution",
        "unsource"
    ]
}
